root = true

charset = "uft-8"

end_of_line = "lf"
trim_trailing_whitespace = true
insert_final_newline = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.lua]
indent_style = tab
indent_size = 4

[*.md]
trim_trailing_whitespace = false
insert_final_newline = true

[justfile]
indent_style = tab
indent_size = 4
